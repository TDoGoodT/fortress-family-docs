DB_PASSWORD=fortress_dev
STORAGE_PATH=./storage
LOG_LEVEL=info
WAHA_API_URL=http://waha:3000
WAHA_API_KEY=
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=fortress
ADMIN_PHONE=972XXXXXXXXX
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# AWS Bedrock — OpenAI-compatible API
# Generate from: AWS Console → Bedrock → API Keys
BEDROCK_API_KEY=
BEDROCK_API_BASE_URL=https://bedrock.us-east-1.amazonaws.com/v1
BEDROCK_MICRO_MODEL=amazon.nova-micro-v1:0
BEDROCK_LITE_MODEL=amazon.nova-lite-v1:0
BEDROCK_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_SONNET_MODEL=us.anthropic.claude-sonnet-4-5-20251001-v1:0

# Document vision fallback (set to false to disable Bedrock vision calls)
DOCUMENT_VISION_FALLBACK_ENABLED=true

# Bot's own WhatsApp number (distinct from ADMIN_PHONE which is the human administrator)
SYSTEM_PHONE=

# Deploy Listener (runs on Mac Mini host)
# Generate with: openssl rand -hex 32
DEPLOY_LISTENER_URL=http://host.docker.internal:9111
DEPLOY_SECRET=

# Coding Agent Integration (Phase C)
# Path to the Codex CLI binary (default: "codex" — assumes it's on PATH)
CODEX_CLI_PATH=codex
# Subprocess timeout in seconds for Codex CLI execution (default: 300)
CODEX_TIMEOUT_SECONDS=300
# Enable Codex CLI execution from Fortress (default: false — prompt generation only)
CODEX_ENABLED=false
# Maximum characters for generated Task_Prompt files (default: 100000)
CODEX_PROMPT_MAX_CHARS=100000
